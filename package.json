{
	"name": "quire",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "tsc",
		"dev": "tsx --env-file-if-exists=.env src/interface/server/index.ts",
		"test": "node --experimental-vm-modules node_modules/.bin/jest --forceExit",
		"lint": "tsc --noEmit"
	},
	"dependencies": {
		"express": "^4.18.0",
		"zod": "^3.22.0",
		"@octokit/rest": "^20.0.0",
		"@octokit/auth-app": "^6.0.3",
		"cookie": "^0.6.0"
	},
	"devDependencies": {
		"@types/express": "^4.17.0",
		"@types/node": "^20.0.0",
		"@types/cookie": "^0.6.0",
		"tsx": "^4.0.0",
		"typescript": "^5.4.0",
		"jest": "^29.0.0",
		"@jest/globals": "^29.0.0",
		"ts-jest": "^29.0.0"
	},
	"jest": {
		"preset": "ts-jest/presets/default-esm",
		"testEnvironment": "node",
		"extensionsToTreatAsEsm": [".ts"],
		"moduleNameMapper": {
			"^(\\.{1,2}/.*)\\.js$": "$1"
		},
		"transform": {
			"^.+\\.tsx?$": ["ts-jest", { "useESM": true }]
		}
	}
}
