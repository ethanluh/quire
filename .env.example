# Copy this file to .env (gitignored) and fill in the values you need.
# `npm run dev` loads .env automatically — no manual exporting required.

# Port the dev server listens on. Defaults to 3000 if unset.
PORT=3000

# Quire's GitHub integration is a GitHub App, not a personal token. Register one at
# https://github.com/settings/apps/new — see README.md's "GitHub App setup" section for
# the exact permissions/events/URLs it needs. During local development the Callback URL
# can point at http://localhost:<PORT>/account/github/oauth/callback; the Setup URL and
# Webhook URL need a real public address (QUIRE_PUBLIC_URL below), so those two only work
# once you're tunneling or deployed.
GITHUB_APP_ID=
GITHUB_APP_SLUG=
# Base64-encode the private key downloaded from the App's settings page and paste the
# single-line result here: `base64 -i your-app.private-key.pem | tr -d '\n'`
# (use `base64 -w0` instead of `-i ... | tr -d '\n'` on Linux).
GITHUB_APP_PRIVATE_KEY_BASE64=
# The App's own OAuth client id/secret (same settings page), used for "Sign in with
# GitHub" — a separate concern from the installation above; this only establishes who is
# signing in, it is never used to call the GitHub API.
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
# Shared secret configured on the App's Webhook settings page.
GITHUB_APP_WEBHOOK_SECRET=

# Comma-separated GitHub logins allowed to sign in. Unset means "anyone with a GitHub
# account can sign in" — fine for local development, but required once hosted (QUIRE_PUBLIC_URL
# is https): the server now refuses to boot with this unset in that case. Set to `*` to
# explicitly allow any GitHub account when hosted, instead of leaving it unset.
QUIRE_ALLOWED_GITHUB_LOGINS=

# Signs Quire's login session cookie. Required in production — rotating it logs out every
# active session. Generate with `openssl rand -hex 32`. If unset, a random one is
# generated per process start (fine for local dev; every session is invalidated on restart).
QUIRE_SESSION_SECRET=

# Needed for the Setup URL (App install callback) and the Webhook URL to work — both
# require a real address GitHub's servers can reach (a tunnel like `ngrok http 3000`, or a
# real deployment). Unrelated to the OAuth callback URL above, which stays localhost-based
# in dev. Leave GITHUB_APP_WEBHOOK_SECRET or this unset to disable the webhook receiver
# entirely (it isn't just rejected, the route is never mounted) and fall back to polling only.
QUIRE_PUBLIC_URL=

# How often Quire re-checks the selected repo for open PRs on its own, independent of
# webhooks — a safety net for a missed webhook delivery, and the sole detection mechanism
# if webhooks aren't configured above. Defaults to 20 minutes if unset.
QUIRE_RECONCILE_INTERVAL_MINUTES=20

# How often Quire proactively fast-forwards queued PRs that have fallen "behind" main (a free
# GitHub merge, no LLM involved) while they wait their turn. Without this, a bundle stuck
# behind others landing ahead of it only gets checked once dequeueNext() finally reaches it —
# by then "behind" may have calcified into a real conflict needing the in-process hunk resolver.
# Defaults to every 5 minutes.
QUIRE_QUEUE_REFRESH_INTERVAL_MINUTES=5

# Where team state (queue.json, installation.json, preferences.json, etc.) is persisted.
# Defaults to ./data relative to the project root. Point this at a mounted volume in
# production so state survives redeploys.
QUIRE_DATA_DIR=

# LLM-backed steps (effect-list extraction for drift detection, merge-conflict hunk
# resolution) need a model account. Set one of ANTHROPIC_API_KEY or GEMINI_API_KEY below and
# LLM_PROVIDER is inferred automatically (Anthropic wins if both are set); set LLM_PROVIDER
# explicitly to be unambiguous. Leave everything in this section unset and Quire falls back
# to a stub provider — the app still runs, but drift detection and auto-conflict-resolution
# are no-ops. Note a team can also connect an LLM account from the running app's Settings UI,
# which takes priority over these env vars.
LLM_PROVIDER=
ANTHROPIC_API_KEY=
# Only needed to point at a non-default Anthropic-compatible endpoint (e.g. a proxy).
ANTHROPIC_BASE_URL=
# Defaults to a recent Haiku model if unset.
ANTHROPIC_MODEL=
GEMINI_API_KEY=
# Defaults to a recent Gemini model if unset.
GEMINI_MODEL=

# Bundle Judge — an LLM-as-judge that scores each drift-cleared bundle against
# docs/judge-constitution.md and, when the constitution's confidence/blast-radius/
# reversibility/risk-taxonomy rule allows it, can act autonomously (merge, self-heal a
# conflict, revert on a failed post-merge check). It NEVER runs on a bundle that failed
# drift detection or spec-conformance — see docs/judge-integration-map.md. Everything below
# is optional; leaving all of it unset gives you shadow mode against the same LLM account
# drift detection already uses (a safe, silent-by-design default — see QUIRE_JUDGE_MODE).

# off | shadow | assist | auto. Defaults to "shadow" if unset: the judge runs and logs a
# verdict for every eligible bundle, but never acts and never surfaces anything to a human —
# it's pure calibration data (data/teams/<teamId>/judge-verdicts.json and
# instrumentation/judge-decisions.ndjson). "off" is a true kill switch (the judge never runs
# at all, not even to log). "assist" surfaces the judge's recommended gesture in the UI; the
# human still swipes. "auto" runs the full gated pipeline — see README.md before enabling
# this in any repo you'd be upset to see auto-merged into.
QUIRE_JUDGE_MODE=

# A SEPARATE, stronger model than the one the swarm/drift-detection pipeline uses, so the
# same model instance never judges the PRs it (or a sibling call) helped produce. Setting
# just this reuses the shared ANTHROPIC_API_KEY/GEMINI_API_KEY above with this model instead;
# for a fully independent account (own billing/key), also set QUIRE_JUDGE_LLM_PROVIDER and
# QUIRE_JUDGE_ANTHROPIC_API_KEY/QUIRE_JUDGE_GEMINI_API_KEY below. Leaving all judge-account
# vars unset makes the judge reuse the exact same account/model as drift detection, logged at
# startup as "bias mitigation OFF" — the judge still runs (in shadow mode by default), just
# without that particular safeguard.
QUIRE_JUDGE_MODEL=
QUIRE_JUDGE_LLM_PROVIDER=
QUIRE_JUDGE_ANTHROPIC_API_KEY=
QUIRE_JUDGE_GEMINI_API_KEY=

# Auto-act thresholds — override docs/judge-constitution.md's own defaults (0.9 / 0.95 / 15)
# without editing the document. autoRejectConfidence must stay greater than
# autoAcceptConfidence (a wrong auto-reject costs a swarm regeneration cycle; a wrong
# auto-accept sits reversibly in the merge queue until it lands) — the process refuses to
# start the judge for a tenant if an override breaks that ordering.
QUIRE_JUDGE_AUTOACCEPT_CONFIDENCE=
QUIRE_JUDGE_AUTOREJECT_CONFIDENCE=
QUIRE_JUDGE_MAX_BLAST_RADIUS_AUTO=
