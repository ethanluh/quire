# Copy this file to .env (gitignored) and fill in the values you need.
# `npm run dev` loads .env automatically — no manual exporting required.

# Port the dev server listens on. Defaults to 3000 if unset.
PORT=3000

# Fallback GitHub credential, used only if no account has been connected through the UI.
GITHUB_TOKEN=

# GitHub OAuth App credentials, needed for the "Sign in with GitHub" connect option.
# Create an OAuth App at https://github.com/settings/developers and set its
# "Authorization callback URL" to exactly http://localhost:<PORT>/account/github/oauth/callback
# (must match PORT above byte-for-byte, or GitHub will reject the exchange).
# Leave both unset to hide the "Sign in with GitHub" button and use the personal-access-token
# connect flow instead.
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# Enables near-real-time PR ingestion via a GitHub webhook instead of relying solely on the
# periodic reconciliation poll below. Requires BOTH vars — leave either unset to disable the
# webhook receiver entirely (it isn't just rejected, the route is never mounted) and fall
# back to polling only.
#
# QUIRE_PUBLIC_URL must be an address GitHub's servers can reach (a tunnel like
# `ngrok http 3000`, or a real deployment) — it is used only to build the webhook's payload
# URL (<QUIRE_PUBLIC_URL>/webhooks/github). It is unrelated to the OAuth callback URL above,
# which stays localhost-based.
# GITHUB_WEBHOOK_SECRET is a shared secret you choose (e.g. `openssl rand -hex 32`) — used
# both to sign the webhook Quire registers and to verify incoming deliveries.
QUIRE_PUBLIC_URL=
GITHUB_WEBHOOK_SECRET=

# How often Quire re-checks the selected repo for open PRs on its own, independent of
# webhooks — a safety net for a missed webhook delivery, and the sole detection mechanism
# if webhooks aren't configured above. Defaults to 20 minutes if unset.
QUIRE_RECONCILE_INTERVAL_MINUTES=20
